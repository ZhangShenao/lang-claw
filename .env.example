# App
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000
DEFAULT_USER_ID=local-user

# Model
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-5
LLM_TEMPERATURE=0.2

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=lang_claw
MONGO_HISTORY_COLLECTION=chat_history
MONGO_PORT=27017

# PostgreSQL
POSTGRES_DB=lang_claw
POSTGRES_USER=langclaw
POSTGRES_PASSWORD=langclaw
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql+asyncpg://langclaw:langclaw@postgres:5432/lang_claw

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lang-claw
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
