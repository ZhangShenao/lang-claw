# Lang Claw Backend - Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
APP_NAME=Lang Claw Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS origins (comma-separated for multiple origins)
CORS_ORIGINS=["http://localhost:3000"]

# Default user ID for local development
DEFAULT_USER_ID=local-user

# ============================================
# LLM Configuration - GLM-5 (智谱 AI)
# ============================================
# Get your API key from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-5
LLM_TEMPERATURE=0.2

# ============================================
# Tavily Search API (for DeepResearch)
# ============================================
# How to get Tavily API Key:
# 1. Visit https://tavily.com/
# 2. Sign up for a free account
# 3. Navigate to API Keys section in your dashboard
# 4. Generate a new API key
#
# Free tier includes:
# - 1,000 searches per month
# - Advanced search capabilities
# - AI-powered answer summaries
TAVILY_API_KEY=tvly-your_api_key_here

# ============================================
# MongoDB Configuration
# ============================================
MONGO_URI=mongodb://mongo:27017
MONGO_DB=lang_claw
MONGO_HISTORY_COLLECTION=chat_history

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_DSN=postgresql+asyncpg://langclaw:langclaw@postgres:5432/lang_claw

# ============================================
# LangSmith Configuration (Observability)
# ============================================
# Get your API key from: https://smith.langchain.com/
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=lang-claw
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
